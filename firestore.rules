rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "niklas.kofler@gmail.com"
        && request.auth.token.email_verified == true;
    }

    function hasOwnerUpdatedBy() {
      return !request.resource.data.keys().hasAny(["updatedBy"])
        || request.resource.data.updatedBy == null
        || request.resource.data.updatedBy == request.auth.token.email;
    }

    match /automationCommands/{commandId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && commandId in [
          "sync_quotes_manual",
          "health_check_manual",
          "flatex_snapshot_refresh",
          "traderepublic_portal_refresh",
          "tfbank_manual_refresh",
          "capitalcom_manual_refresh"
        ]
        && request.resource.data.keys().hasOnly([
          "type",
          "status",
          "requestedBy",
          "requestedAt",
          "updatedAt"
        ])
        && (
          (commandId == "sync_quotes_manual"
            && request.resource.data.type == "sync_quotes")
          ||
          (commandId == "health_check_manual"
            && request.resource.data.type == "health_check")
          ||
          (commandId == "flatex_snapshot_refresh"
            && request.resource.data.type == "flatex_refresh")
          ||
          (commandId == "traderepublic_portal_refresh"
            && request.resource.data.type == "traderepublic_portal_refresh")
          ||
          (commandId == "tfbank_manual_refresh"
            && request.resource.data.type == "tfbank_refresh")
          ||
          (commandId == "capitalcom_manual_refresh"
            && request.resource.data.type == "capitalcom_refresh")
        )
        && request.resource.data.status == "REQUESTED";
      allow delete: if false;
    }

    match /documentReviewDecisions/{decisionId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && request.resource.data.keys().hasOnly([
          "source",
          "scope",
          "decision",
          "status",
          "targetId",
          "targetSignature",
          "targetLabel",
          "targetDocumentType",
          "reason",
          "decidedBy",
          "decidedAt",
          "updatedAt"
        ])
        && request.resource.data.source is string
        && request.resource.data.scope in ["item", "document_type"]
        && request.resource.data.decision in ["covered", "not_relevant", "needs_parser", "deferred"]
        && request.resource.data.status == "ACTIVE";
      allow delete: if false;
    }

    match /manualInputs/{inputId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && (
          (
            inputId == "equateplus_novartis"
            && request.resource.data.keys().hasOnly([
              "source",
              "instrumentId",
              "isin",
              "name",
              "quantity",
              "entryValueEur",
              "entryValueCurrency",
              "discountPct",
              "updatedBy",
              "updatedAt"
            ])
            && request.resource.data.source == "equateplus"
            && request.resource.data.instrumentId == "novartis"
            && request.resource.data.isin == "CH0012005267"
            && request.resource.data.name == "Novartis"
            && request.resource.data.quantity is number
            && request.resource.data.quantity >= 0
            && request.resource.data.entryValueEur is number
            && request.resource.data.entryValueEur >= 0
            && request.resource.data.entryValueCurrency == "EUR"
            && request.resource.data.discountPct is number
            && hasOwnerUpdatedBy()
            && request.resource.data.updatedAt is timestamp
          )
          ||
          (
            inputId == "cash_home"
            && request.resource.data.keys().hasOnly([
              "source",
              "amountEur",
              "currency",
              "updatedBy",
              "updatedAt"
            ])
            && request.resource.data.source == "cash_home"
            && request.resource.data.amountEur is number
            && request.resource.data.amountEur >= 0
            && request.resource.data.currency == "EUR"
            && hasOwnerUpdatedBy()
            && request.resource.data.updatedAt is timestamp
          )
        );
      allow delete: if false;
    }

    match /uiPreferences/{preferenceId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && preferenceId == "portfolio_overview"
        && request.resource.data.keys().hasOnly([
          "expandedSections",
          "sourceOrder",
          "updatedBy",
          "updatedAt"
        ])
        && request.resource.data.keys().hasAny(["expandedSections", "sourceOrder"])
        && (!request.resource.data.keys().hasAny(["expandedSections"])
          || request.resource.data.expandedSections is map)
        && (!request.resource.data.keys().hasAny(["sourceOrder"])
          || request.resource.data.sourceOrder is list)
        && hasOwnerUpdatedBy()
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }
  }
}
