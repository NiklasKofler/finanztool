rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "niklas.kofler@gmail.com"
        && request.auth.token.email_verified == true;
    }

    match /automationCommands/{commandId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && commandId in ["sync_quotes_manual", "traderepublic_portal_refresh"]
        && request.resource.data.keys().hasOnly([
          "type",
          "status",
          "requestedBy",
          "requestedAt",
          "updatedAt"
        ])
        && (
          (commandId == "sync_quotes_manual"
            && request.resource.data.type == "sync_quotes")
          ||
          (commandId == "traderepublic_portal_refresh"
            && request.resource.data.type == "traderepublic_portal_refresh")
        )
        && request.resource.data.status == "REQUESTED";
      allow delete: if false;
    }

    match /documentReviewDecisions/{decisionId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && request.resource.data.keys().hasOnly([
          "source",
          "scope",
          "decision",
          "status",
          "targetId",
          "targetSignature",
          "targetLabel",
          "targetDocumentType",
          "reason",
          "decidedBy",
          "decidedAt",
          "updatedAt"
        ])
        && request.resource.data.source is string
        && request.resource.data.scope in ["item", "document_type"]
        && request.resource.data.decision in ["covered", "not_relevant", "needs_parser", "deferred"]
        && request.resource.data.status == "ACTIVE";
      allow delete: if false;
    }

    match /manualInputs/{inputId} {
      allow read: if isOwner();
      allow create, update: if isOwner()
        && inputId == "equateplus_novartis"
        && request.resource.data.keys().hasOnly([
          "source",
          "instrumentId",
          "isin",
          "name",
          "quantity",
          "entryValueEur",
          "entryValueCurrency",
          "discountPct",
          "updatedBy",
          "updatedAt"
        ])
        && request.resource.data.source == "equateplus"
        && request.resource.data.instrumentId == "novartis"
        && request.resource.data.isin == "CH0012005267"
        && request.resource.data.name == "Novartis"
        && request.resource.data.quantity is number
        && request.resource.data.quantity >= 0
        && request.resource.data.entryValueEur is number
        && request.resource.data.entryValueEur >= 0
        && request.resource.data.entryValueCurrency == "EUR"
        && request.resource.data.discountPct is number
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /{document=**} {
      allow read: if isOwner();
      allow write: if false;
    }
  }
}
