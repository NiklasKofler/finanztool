#!/bin/zsh
set -euo pipefail

REPO="/Users/niklaskofler/Documents/finanztool"
cd "$REPO"
source "$HOME/.zshrc" >/dev/null 2>&1 || true

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  node automation/src/project-workflow.mjs upload-pre --help
  exit 0
fi

nvm use >/dev/null
node automation/src/project-workflow.mjs upload-pre "$@"

FIREBASE_BIN="$HOME/.nvm/versions/node/v20.19.3/bin/firebase"
if [[ ! -x "$FIREBASE_BIN" ]]; then
  FIREBASE_BIN="$(command -v firebase)"
fi

DEPLOY_OK=0
for ATTEMPT in 1 2 3 4 5; do
  if [[ "$ATTEMPT" -gt 1 ]]; then
    echo "Firebase Deploy Versuch $ATTEMPT/5 nach Retry..."
  fi

  if env -i \
    HOME="$HOME" \
    USER="$USER" \
    PATH="$HOME/.nvm/versions/node/v20.19.3/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin" \
    LANG="${LANG:-en_US.UTF-8}" \
    NODE_OPTIONS="--dns-result-order=ipv4first" \
    "$FIREBASE_BIN" deploy --only hosting --project finanzperformance-tool; then
    DEPLOY_OK=1
    break
  fi

  sleep $((ATTEMPT * 5))
done

if [[ "$DEPLOY_OK" -ne 1 ]]; then
  echo "FEHLER: Firebase Deploy ist nach 5 Versuchen fehlgeschlagen." >&2
  exit 1
fi

exec node automation/src/project-workflow.mjs upload-finalize
