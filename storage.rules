rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == "niklas.kofler@gmail.com";
    }

    match /{allPaths=**} {
      allow read: if isOwner();
      allow write: if false;
    }
  }
}
